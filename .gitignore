###############################################################################
# NARO-LIMS .gitignore
# Purpose: Prevent accidental commits of generated, local, or sensitive files
###############################################################################

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
ENV/
env/

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
db.sqlite3
db.sqlite3-journal
db.sqlite3.bak
/media/
/staticfiles/
/logs/

# Django secrets
.env
.env.*
*.local

# ---------------------------------------------------------------------------
# Celery / background processing
# ---------------------------------------------------------------------------
celerybeat-schedule

# ---------------------------------------------------------------------------
# Local artifacts / scratch files
# ---------------------------------------------------------------------------
*.save
*.log
cookies.txt

# ---------------------------------------------------------------------------
# Project-specific local-only files
# ---------------------------------------------------------------------------
lims_core/workflows_py_unused.bak
lims_core/management/commands/show_urls.py
